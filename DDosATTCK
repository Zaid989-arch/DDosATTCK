def format_count(n):
    if n >= 1_000_000:
        return f"{n/1_000_000:.2f}M"
    elif n >= 1_000:
        return f"{n/1_000:.2f}K"
    return str(n)

def get_speed(delta_t, delta_p):
    if delta_t <= 0:
        return 0
    return int(delta_p / delta_t)

